$SIZES PD=-150
$PROBLEM
$DATA ../../data/derived/SHR3680_combined_POPPK_11AUG2021_NONMEM.csv IGNORE=C  IGNORE=C ACCEPT=(CYCLE.GT.1)
$INPUT C ID ST CENT SID DOSE AMT DAY TIME TAD DV MDV EVID II ADDL AGE ETHICS
  NATION BW Hb RBC WBC Neut LY PLT PRO ERY TBIL ALT AST AKP GGT TP ALB UA Cr
  CLCr CHO TG PT LDH FORM CT STG META ECOG RTH ASIA STG_LE3
$SUBROUTINE ADVAN13 TOL=10
$MODEL
COMP = (DEPOT,DEFDOSE)
COMP = (CENTRAL,DEFOBS)
COMP = (ENZ)
$PK
TVKA    = THETA(1)
TVV     = THETA(2)
TVCL    = THETA(3)
TVKENZ  = THETA(4)  ; KENZ (H-1)
TVEC50  = THETA(5)  ; EC50 (MG/L)
TVEMAX  = THETA(6)  ; EMAX

KA      = TVKA   * EXP(ETA(1))
V       = TVV    * EXP(ETA(2))
CL      = TVCL   * EXP(ETA(3))
KENZ    = TVKENZ * EXP(ETA(4))
EC50    = TVEC50 * EXP(ETA(5))
EMAX    = TVEMAX * EXP(ETA(6))

S2      = V

$DES
CONC    = A(2)/V
DADT(1) = -KA*A(1)
DADT(2) =  KA*A(1) - CL * CONC * A(3)
DADT(3) =  KENZ*(1 + (EMAX*CONC) / (EC50 + CONC)) - KENZ*A(3)

$ERROR
W            = 1
IF(F.GT.0) W = SQRT(THETA(7)**2+THETA(8)**2*F**2)
IPRED        = F
IRES         = DV-IPRED
IWRES        = IRES / W
Y            = IPRED+EPS(1)*W

$THETA
  (0,9.2956E-01)  ; KA
  (0,3.1594E+01)  ; V
  (0,2.2680E-01)  ; CL
  (0,1.2210E+00)  ; KENZ
  (0,9.1937E+05)  ; EC50
  (0,9.6505E+03)  ; EMAX
  1
  1
$OMEGA
  3.5758E-01
  2.6098E-02
  4.9416E-02
  1.2615E-05
  3.8878E-05
  3.8205E-01
$SIGMA 3.1531E-02

$ESTIMATION METHOD=1 INTER MAXEVAL=9999 NSIG=3 SIGL=9 PRINT=3 MCETA=100
$COVARIANCE
$TABLE ID TIME IPRED IWRES CWRES NOPRINT ONEHEADER FILE=sdtab006
$TABLE ID KA CL V NOPRINT ONEHEADER FILE=patab006

