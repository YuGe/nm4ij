;; 1. Based on: run008.2.2.4_F

$PROBLEM
$INPUT     C ID ST SID AMT RATE TIME DV MDV EVID SEX RACE ALB ADA
$DATA      SHR-1210_20210127_NM_SIM_II_11.csv IGNORE=C
$SUBROUTINE ADVAN6 TOL=6
$MODEL      COMP=(CENTRAL,DEFDOS,DEFOBS) COMP=(PERIPH)
$PK
;;; V1SEX-DEFINITION START
V1SEX=THETA(13)**SEX
;;; V1SEX-DEFINITION END


;;; V1RACE-DEFINITION START
V1RACE=THETA(12)**RACE
;;; V1RACE-DEFINITION END

;;; V1-RELATION START
V1COV=V1RACE*V1SEX
;;; V1-RELATION END


;;; CLLINSEX-DEFINITION START
CLLINSEX=THETA(11)**SEX
;;; CLLINSEX-DEFINITION END


;;; CLLINALB-DEFINITION START
   CLLINALB = ((ALB/42.8)**THETA(10))
;;; CLLINALB-DEFINITION END


;;; CLLINADA-DEFINITION START
CLLINADA=THETA(9)**ADA
;;; CLLINADA-DEFINITION END

;;; CLLIN-RELATION START
CLLINCOV=CLLINADA*CLLINALB*CLLINSEX
;;; CLLIN-RELATION END


  TVCLLIN   = THETA(1)

TVCLLIN = CLLINCOV*TVCLLIN
  TVVM   = THETA(2)
  TVKM   = THETA(3)
  TVV1   = THETA(4)

TVV1 = V1COV*TVV1
  TVQ    = THETA(5)
  TVV2   = THETA(6)
  CLLIN  = TVCLLIN * EXP(ETA(1))
  VM     = TVVM * EXP(ETA(3))
  KM     = TVKM* EXP(ETA(4))
  V1     = TVV1* EXP(ETA(2))
  Q      = TVQ  * EXP(ETA(5))
  V2     = TVV2* EXP(ETA(6))
  K12    = Q/V1
  K21    = Q/V2
  S1     = V1

$DES
  CONC     = A(1)/V1
  CLNONLIN = VM/(KM+CONC)
  CL       = CLLIN+CLNONLIN
  K10      = CL/V1
  DADT(1) =  -K10*A(1)- K12*A(1) + K21*A(2)
  DADT(2) =             K12*A(1) - K21*A(2)

$ERROR
WA=THETA(7)
WP=THETA(8)
IF(F.GT.0) IPRED = F
W= SQRT(WA**2+(WP*IPRED)**2)
IRES  = IPRED-DV
IWRES = IRES/W
Y= IPRED+ERR(1)*W

$THETA  (0,0.250512) ; CLLIN
 (0,3.21133) ; VM
 (0,1.27061) ; KM
 (0,3.38907) ; V1
 (0,0.387929) ; Q
 (0,3.17746) ; V2
 -0.154955 ; add
 -0.185604 ; prop
$THETA  (0,1.2404,  5.00) ; CLLINADA1
$THETA  (-100,-0.930888,100000) ; CLLINALB1
$THETA  (0,0.782988,  5.00) ; CLLINSEX1
$THETA  (0,1.12807,  5.00) ; V1RACE1
$THETA  (0,0.810831,  5.00) ; V1SEX1
$OMEGA  BLOCK(2)
 0.172628
 0.0391214 0.0334298
$OMEGA  0.13582
 0  FIX
 0  FIX
 0  FIX
$SIGMA  1  FIX
$SIM  (54321) ONLYSIM SUBPROBLEMS=1000

$TABLE ID ST SID TIME Y PRED IPRED CL CLLIN CLNONLIN VM KM V1 Q V2 ETA1 ETA2 ETA3 ETA4 ETA5 ETA6 EVID MDV IWRES CWRES NOPRINT NOAPPEND ONEHEADER FILE=008.2.2.4_F_scm9_sim_ii_11.fit
