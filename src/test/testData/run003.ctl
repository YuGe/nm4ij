$PROBLEM DBPR108 PopPK
$INPUT C ID STN AMT TIME TAD DV MDV EVID II ADDL CYCLE
$DATA DBPR108_PPK_NM_C3.csv IGNORE=C IGNORE=(STN .NE. 7)
$SUBROUTINE ADVAN6 TOL=6
$MODEL
COMP=(DEPOT1)
COMP=(DEPOT2)
COMP=(CENTRAL,DEFOBS)
COMP=(PERIPH)

$ABBR DECLARE DOSETIME(100), DOSE(100)
$ABBR DECLARE DOWHILE I
$ABBR DECLARE DOWHILE NDOSE

$PK
CALLFL=-2
IF (NEWIND < 2) NDOSE=0
IF (AMT > 0) THEN
 NDOSE=NDOSE+1
 DOSETIME(NDOSE)=TIME
 DOSE(NDOSE)=AMT
ENDIF

FR1   = THETA(1)*EXP(ETA(1))
KA1   = THETA(2)*EXP(ETA(2))
ALAG1 = THETA(3)*EXP(ETA(3))
FR2   = THETA(4)*EXP(ETA(4))
KA2   = THETA(5)*EXP(ETA(5))
MTT   = THETA(6)*EXP(ETA(6))
NN    = THETA(7)*EXP(ETA(7))
CL    = THETA(8)*EXP(ETA(8))
V3    = THETA(9)*EXP(ETA(9))
Q4    = THETA(10)
V4    = THETA(11)

S3 = V3
S4 = V4

K30 = CL/V3
K34 = Q4/V3
K43 = Q4/V4

F1 = FR1
F2 = 0

KTR  = (NN + 1)/MTT
NFAC = SQRT(2*3.1416)*NN**(NN+0.5)*(EXP(-NN))*(1+1/(12*NN))
KINPT= FR2*KTR**(NN+1)/NFAC

$DES
INPT=0
I=1
DOWHILE (I <= NDOSE)
IPT=0
IF (T >= DOSETIME(I)) IPT=DOSE(I)*(T-DOSETIME(I))**NN*EXP(-KTR*(T-DOSETIME(I)))
INPT=INPT+IPT
I=I+1
ENDDO

DADT(1) = -KA1*A(1)
DADT(2) = KINPT*INPT - KA2*A(2)
DADT(3) = KA1*A(1) + KA2*A(2) + K43*A(4) - K30*A(3) - K34*A(3)
DADT(4) = K34*A(3) - K43*A(4)

$ERROR
IPRED = F
IRES = DV - IPRED
IWRES = 0
IF(F .NE. 0) IWRES = IRES/F
Y = F + F*EPS(1)

$THETA
(0,9E-02,1) ; FR1
(0,8E-01)   ; KA1
(0,2E+00)   ; ALAG1
(0,1E-01,1) ; FR2
(0,4E+00)   ; KA2
(0,4E-01)   ; MTT
(0,6E+00)   ; NN
(0,1E+01)   ; CL
(0,6E+01)   ; V3
(0,1E+00)   ; Q4
(0,4E+01)   ; V4

$OMEGA
4E-01 ; FR1_
1E+00 ; KA1_
0 FIX ; ALAG1_
$OMEGA BLOCK(2)
2E-01 ; FR2_
-3E-01 1E+00 ; KA2_
$OMEGA
1E-01 ; MTT_
0 FIX ; NN_
2E-02 ; CL_
1E-01 ; V3_

$SIGMA
6E-02 ; EPS_

$ESTIMATION METHOD=1 INTER MAXEVAL=9999 NSIG=2 SIGL=4 PRINT=5 POSTHOC
$COVARIANCE MATRIX=R PRINT=E
$TABLE ID TIME AMT DV PRED IPRED RES WRES IWRES CWRES
       NOAPPEND NOPRINT ONEHEADER FORMAT=sES13.6 FILE=sdtab205
$TABLE ID FR1 KA1 ALAG1 FR2 KA2 MTT NN CL V3 Q4 V4
       ETA1 ETA2 ETA3 ETA4 ETA5 ETA6 ETA7 ETA8 ETA9
       NOAPPEND NOPRINT ONEHEADER FORMAT=sES13.6 FILE=patab205
$TABLE ID TAD MDV EVID STN CYCLE
       NOAPPEND NOPRINT ONEHEADER FORMAT=sES13.6 FILE=extra205
